'use client';

import { useState, useEffect } from 'react';

interface Message { id: string; from: string; content: string; receivedAt: number; }
interface TempNumber { id: string; number: string; country: string; messages: Message[]; expiresAt: number; createdAt: number; }

export default function Home() {
  const [numbers, setNumbers] = useState<TempNumber[]>([]);
  const [newNumber, setNewNumber] = useState('');
  const [country, setCountry] = useState('US');
  const [ttl, setTtl] = useState(60);
  const [loading, setLoading] = useState(false);

  const fetchNumbers = async () => {
    const res = await fetch('/api/numbers');
    const data = await res.json();
    if (data.success) setNumbers(data.data);
  };

  useEffect(() => { fetchNumbers(); const interval = setInterval(fetchNumbers, 5000); return () => clearInterval(interval); }, []);

  const createNumber = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    await fetch('/api/numbers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ number: newNumber, country, ttlMinutes: ttl }) });
    setNewNumber('');
    await fetchNumbers();
    setLoading(false);
  };

  const deleteNumber = async (id: string) => { await fetch(`/api/numbers/${id}`, { method: 'DELETE' }); fetchNumbers(); };
  const clearAll = async () => { await fetch('/api/numbers', { method: 'DELETE' }); fetchNumbers(); };

  const formatTime = (ts: number) => new Date(ts).toLocaleTimeString();
  const getTimeLeft = (exp: number) => { const mins = Math.floor((exp - Date.now()) / 60000); return mins > 0 ? `${mins}m` : 'Expired'; };

  return (
    <div className="min-h-screen bg-gray-50 p-8">
      <div className="max-w-4xl mx-auto">
        <div className="flex justify-between items-center mb-8">
          <h1 className="text-3xl font-bold text-gray-800">Bot Testing Number DB</h1>
          <button onClick={clearAll} className="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600">Clear All</button>
        </div>

        <div className="bg-white rounded-lg shadow p-6 mb-6">
          <h2 className="text-lg font-semibold mb-4">Add Temporary Number</h2>
          <form onSubmit={createNumber} className="flex gap-4 flex-wrap">
            <input type="text" placeholder="+1 555-0123" value={newNumber} onChange={(e) => setNewNumber(e.target.value)} className="flex-1 min-w-[200px] px-4 py-2 border rounded-lg" required />
            <select value={country} onChange={(e) => setCountry(e.target.value)} className="px-4 py-2 border rounded-lg">
              <option value="US">US</option>
              <option value="UK">UK</option>
              <option value="CA">CA</option>
              <option value="AU">AU</option>
              <option value="DE">DE</option>
            </select>
            <select value={ttl} onChange={(e) => setTtl(Number(e.target.value))} className="px-4 py-2 border rounded-lg">
              <option value={15}>15 min</option>
              <option value={30}>30 min</option>
              <option value={60}>1 hour</option>
              <option value={240}>4 hours</option>
            </select>
            <button type="submit" disabled={loading} className="px-6 py-2 bg-blue-600 text-white rounded-lg disabled:opacity-50">{loading ? 'Adding...' : 'Add Number'}</button>
          </form>
        </div>

        <div className="space-y-4">
          {numbers.length === 0 && <div className="text-center py-12 text-gray-500 bg-white rounded-lg">No active numbers. Add one above.</div>}
          {numbers.map((num) => (
            <div key={num.id} className="bg-white rounded-lg shadow p-6">
              <div className="flex justify-between items-start mb-4">
                <div>
                  <div className="flex items-center gap-3">
                    <span className="text-2xl font-mono font-bold text-gray-800">{num.number}</span>
                    <span className="px-2 py-1 bg-gray-100 text-sm rounded">{num.country}</span>
                    <span className="px-2 py-1 bg-green-100 text-green-800 text-sm rounded">{getTimeLeft(num.expiresAt)} left</span>
                  </div>
                  <div className="text-sm text-gray-500 mt-1">ID: <code className="bg-gray-100 px-1 rounded">{num.id}</code> • Created: {formatTime(num.createdAt)}</div>
                </div>
                <button onClick={() => deleteNumber(num.id)} className="text-red-500 hover:text-red-700">Delete</button>
              </div>
              <div className="bg-gray-50 rounded-lg p-4">
                <h3 className="text-sm font-semibold text-gray-600 mb-2">Messages ({num.messages.length})</h3>
                {num.messages.length === 0 ? <p className="text-sm text-gray-400 italic">No messages yet</p> : (
                  <div className="space-y-2">
                    {num.messages.map((msg) => (
                      <div key={msg.id} className="bg-white p-3 rounded border text-sm">
                        <div className="flex justify-between text-xs text-gray-500 mb-1"><span>From: {msg.from}</span><span>{formatTime(msg.receivedAt)}</span></div>
                        <p className="text-gray-800">{msg.content}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
